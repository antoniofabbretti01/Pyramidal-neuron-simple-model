   "source": [
    "# Activation and inhactivations curves of Na+ channel\n",
    "\n",
    "m_ = m_inf_Na\n",
    "h_ = h_inf_Na\n",
    "g_ = np.zeros(len(m_))\n",
    "for i in range(len(m_)):\n",
    "    g_[i]=(m_[i]**3)*h_[i]\n",
    "plt.plot(vs,m_,'r',label='m_inf')  # Activation variable\n",
    "plt.plot(vs,h_,'b',label='h_inf')  # Inhactivation variable\n",
    "plt.plot(vs,g_,'k',label='OP_inf')\n",
    "plt.xlabel('Membrane potential (mV)')\n",
    "plt.legend()\n",
    "plt.title('Curves of Na+ channel')\n",
    "plt.grid();"
   ]
