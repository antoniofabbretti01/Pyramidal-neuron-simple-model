   "source": [
    "# Required libreries\n",
    "\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import neuron\n",
    "from neuron import h\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "b6cc22bb",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Model morphology\n",
    "\n",
    "As = 0.015 # As: soma area in mm2\n",
    "Ad = 0.035 # Ad: dendrite area in mm2\n",
    "\n",
    "soma = h.Section(name='soma')\n",
    "soma.L    = 70  # Soma length in μm\n",
    "soma.diam = 68  # Soma diameter in μm\n",
    "soma.nseg = 1   # Number of segments of the soma\n",
    "soma.cm   = 1   # Membrane capacitance in μF/cm2     \n",
    "\n",
    "dend = h.Section(name='dend')\n",
    "dend.L     = 680  # Dendrite length in μm\n",
    "dend.diam  = 17   # Dendrite diameter in μm\n",
    "dend.nseg  = 1    # Number of segments of the dendrite\n",
    "dend.cm    = 1    # Membrane capacitance in μF/cm2   \n",
    "\n",
    "# Dendrite sizes chosen to have coupling between soma and dendrite with a conductance of 1.75 μS,\n",
    "# corrisponding to an axial resistance (dend.ri) of 0.57 MΩ.\n",
    "\n",
    "h.celsius  = 30   # Temperature in Celsius degrees\n",
    "dend.connect(soma(1),0);  # To connect the top of the dendrite to the bottom of the soma\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "11263cdd",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Mechanisms\n",
    "\n",
    "soma.insert('KNa') \n",
    "soma.insert('KDR') \n",
    "soma.insert('Na') \n",
    "soma.insert('KS')\n",
    "soma.insert('KA')\n",
    "soma.insert('leak')\n",
    "\n",
    "dend.insert('NaP') \n",
    "dend.insert('KAR')\n",
    "dend.insert('KCa')\n",
    "dend.insert('Ca')\n",
    "dend.insert('leak') \n",
    "\n",
    "# Mechanisms taken from Compte model except for following, taken from Dalla Porta.\n",
    "dend.insert('Ih') \n",
    "soma.insert('IM'); \n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 4,
   "id": "9fc4a3e6",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Mechanisms parameters modification FORSE DA TOGLIERE \n",
    "dend.gH_Ih = 0.0115e-3*0\n",
    "soma.gM_IM = 0.083e-3*0\n",
    "soma.gL_leak = 0.0667e-3*0.3 # *0.3 *0.18\n",
    "dend.gL_leak = 0.0667e-3*0.3 # *0.3 *0.18\n",
    "#soma.NaCeq_KNa = 9.5 # Nel paper di Compte è prima 0, poi 9.5 (e in tal caso vL=-63), nel modello di Dalla Porta è 0.\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "34d72129",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Modifications of Dalla Porta respect to Compte original model.\n",
    "Author='DP'\n",
    "if Author=='DP':\n",
    "    soma.gKNa_KNa=soma.gKNa_KNa#*0.56\n",
    "    soma.gKA_KA=soma.gKA_KA#*0.9 \n",
    "    soma.gKS_KS=soma.gKS_KS#*0.7 \n",
    "    dend.gH_Ih=0.0115e-3 # S/cm2\n",
    "    soma.gM_IM=0.083e-3 # S/cm2\n",
    "    "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "7612f9ad",
   "metadata": {},
   "outputs": [
